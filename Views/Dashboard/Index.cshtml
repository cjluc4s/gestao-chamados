@model gestao_chamados.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Total</h6><h3>@Model.TotalTickets</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Abertos</h6><h3>@Model.OpenTickets</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>Resolvidos</h6><h3>@Model.ResolvedTickets</h3></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><h6>SLA vencido</h6><h3>@Model.SlaBreachedTickets</h3></div></div></div>
</div>

<div class="card">
    <div class="card-header">Chamados por prioridade</div>
    <div class="card-body">
        <ul class="list-group list-group-flush">
            @foreach (var item in Model.ByPriority.OrderBy(x => x.Key))
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span>@item.Key</span>
                    <strong>@item.Value</strong>
                </li>
            }
        </ul>
    </div>
</div>
