@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<div class="error-panel">
    <h1>Erro</h1>
    <h2>Ocorreu um problema ao processar sua solicitação.</h2>

    @if (Model.ShowRequestId)
    {
        <p class="mt-3">
            <strong>ID da requisição:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a class="btn btn-primary mt-3" asp-controller="Home" asp-action="Index">Voltar ao início</a>
</div>
