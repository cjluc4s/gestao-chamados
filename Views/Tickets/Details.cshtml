@model gestao_chamados.Models.ViewModels.TicketDetailsViewModel
@using gestao_chamados.Models
@{
    ViewData["Title"] = $"Chamado #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Chamado #@Model.Id - @Model.Title</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-body">
                <p>@Model.Description</p>
                <hr />
                <p class="mb-1"><strong>Categoria:</strong> @Model.Category</p>
                <p class="mb-1"><strong>Status:</strong> @Model.Status</p>
                <p class="mb-1"><strong>Prioridade:</strong> @Model.Priority</p>
                <p class="mb-1"><strong>Criado por:</strong> @Model.CreatedBy</p>
                <p class="mb-0"><strong>Atribuído para:</strong> @(Model.AssignedTo ?? "Não atribuído")</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Interações</div>
            <div class="card-body">
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted">Sem interações ainda.</p>
                }
                else
                {
                    foreach (var comment in Model.Comments)
                    {
                        <div class="border rounded p-2 mb-2 @(comment.IsAgent ? "bg-light" : "")">
                            <div class="d-flex justify-content-between">
                                <strong>@comment.Author</strong>
                                <small>@comment.CreatedAtUtc.ToLocalTime()</small>
                            </div>
                            <div>@comment.Message</div>
                        </div>
                    }
                }

                <form method="post" asp-action="AddComment" class="mt-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <textarea name="message" class="form-control mb-2" rows="3" placeholder="Digite uma resposta..."></textarea>
                    <button type="submit" class="btn btn-primary">Responder</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">SLA</div>
            <div class="card-body">
                <p><strong>Limite:</strong> @(Model.DueAtUtc?.ToLocalTime().ToString("g") ?? "-")</p>
                @if (Model.IsSlaBreached)
                {
                    <span class="badge text-bg-danger">SLA vencido</span>
                }
                else
                {
                    <span class="badge text-bg-success">Dentro do SLA</span>
                }
            </div>
        </div>

        @if (User.IsInRole(RoleNames.Agent) || User.IsInRole(RoleNames.Admin))
        {
            <div class="card mb-3">
                <div class="card-header">Ações</div>
                <div class="card-body">
                    <form method="post" asp-action="ChangeStatus">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="status" class="form-select mb-2" asp-items="Html.GetEnumSelectList<TicketStatus>()"></select>
                        <button type="submit" class="btn btn-outline-primary w-100">Alterar status</button>
                    </form>

                    @if (User.IsInRole(RoleNames.Agent) && string.IsNullOrWhiteSpace(Model.AssignedTo))
                    {
                        <form method="post" asp-action="AssignToMe" class="mt-2">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-secondary w-100">Assumir chamado</button>
                        </form>
                    }
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">Histórico de status</div>
            <div class="card-body">
                @if (!Model.History.Any())
                {
                    <p class="text-muted">Sem histórico.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.History)
                        {
                            <li class="list-group-item px-0">
                                <div><strong>@(item.FromStatus?.ToString() ?? "(inicial)")</strong> → <strong>@item.ToStatus</strong></div>
                                <small>@item.ChangedBy em @item.ChangedAtUtc.ToLocalTime()</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
