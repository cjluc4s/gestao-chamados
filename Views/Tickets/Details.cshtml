@model gestao_chamados.Models.ViewModels.TicketDetailsViewModel
@using gestao_chamados.Models
@{
    ViewData["Title"] = $"Chamado #{Model.Id}";
}

@functions {
    string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title mb-0">Chamado #@Model.Id - @Model.Title</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card surface-card mb-3">
            <div class="card-body">
                <p>@Model.Description</p>
                <hr />
                <div class="details-meta">
                    <p><strong>Categoria:</strong> @Model.Category</p>
                    <p>
                        <strong>Status:</strong>
                        @{
                            var sCss = Model.Status switch
                            {
                                TicketStatus.Open => "open",
                                TicketStatus.InProgress => "inprogress",
                                TicketStatus.WaitingUser => "waitinguser",
                                TicketStatus.Resolved => "resolved",
                                TicketStatus.Closed => "closed",
                                _ => "open"
                            };
                            var sLabel = Model.Status switch
                            {
                                TicketStatus.Open => "Aberto",
                                TicketStatus.InProgress => "Em andamento",
                                TicketStatus.WaitingUser => "Aguardando",
                                TicketStatus.Resolved => "Resolvido",
                                TicketStatus.Closed => "Fechado",
                                _ => Model.Status.ToString()
                            };
                        }
                        <span class="badge-status @sCss">@sLabel</span>
                    </p>
                    <p>
                        <strong>Prioridade:</strong>
                        @{
                            var pCss = Model.Priority switch
                            {
                                TicketPriority.Low => "low",
                                TicketPriority.Medium => "medium",
                                TicketPriority.High => "high",
                                TicketPriority.Critical => "critical",
                                _ => "low"
                            };
                            var pLabel = Model.Priority switch
                            {
                                TicketPriority.Low => "Baixa",
                                TicketPriority.Medium => "Média",
                                TicketPriority.High => "Alta",
                                TicketPriority.Critical => "Crítica",
                                _ => Model.Priority.ToString()
                            };
                        }
                        <span class="badge-priority @pCss">@pLabel</span>
                    </p>
                    <p><strong>Criado por:</strong> @Model.CreatedBy</p>
                    <p class="mb-0"><strong>Atribuído para:</strong> @(Model.AssignedTo ?? "Não atribuído")</p>
                </div>
            </div>
        </div>

        <div class="card surface-card mb-3">
            <div class="card-header">Anexos</div>
            <div class="card-body">
                @if (!Model.Attachments.Any())
                {
                    <p class="text-muted">Sem anexos.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var att in Model.Attachments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center attachment-item">
                                <div>
                                    <span class="attachment-icon">📎</span>
                                    <a asp-action="Download" asp-route-id="@att.Id" class="attachment-link">@att.FileName</a>
                                    <small class="text-muted ms-2">(@FormatFileSize(att.SizeInBytes))</small>
                                </div>
                                <small class="text-muted">@att.UploadedBy · @att.UploadedAtUtc.ToLocalTime().ToString("g")</small>
                            </li>
                        }
                    </ul>
                }

                <form method="post" asp-action="UploadToTicket" enctype="multipart/form-data" class="mt-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="input-group">
                        <input type="file" name="files" class="form-control" multiple accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip,.rar" />
                        <button type="submit" class="btn btn-outline-primary">Enviar</button>
                    </div>
                    <small class="form-text text-muted">Máx. 10 MB por arquivo.</small>
                </form>
            </div>
        </div>

        <div class="card surface-card mb-3">
            <div class="card-header">Interações</div>
            <div class="card-body">
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted">Sem interações ainda.</p>
                }
                else
                {
                    foreach (var comment in Model.Comments)
                    {
                        <div class="comment-bubble mb-2 @(comment.IsAgent ? "agent" : "")">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="comment-author">@comment.Author</span>
                                <span class="comment-time">@comment.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                            </div>
                            <div class="comment-text">@comment.Message</div>
                        </div>
                    }
                }

                <form method="post" asp-action="AddComment" class="mt-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <textarea name="message" class="form-control mb-2" rows="3" placeholder="Digite uma resposta..."></textarea>
                    <button type="submit" class="btn btn-primary">Responder</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card surface-card mb-3">
            <div class="card-header">SLA</div>
            <div class="card-body">
                <p><strong>Limite:</strong> @(Model.DueAtUtc?.ToLocalTime().ToString("g") ?? "-")</p>
                @if (Model.IsSlaBreached)
                {
                    <span class="badge-sla breach">⚠ SLA vencido</span>
                }
                else
                {
                    <span class="badge-sla ok">✓ Dentro do SLA</span>
                }
            </div>
        </div>

        @if (User.IsInRole(RoleNames.Agent) || User.IsInRole(RoleNames.Admin))
        {
            <div class="card surface-card mb-3">
                <div class="card-header">Ações</div>
                <div class="card-body">
                    <form method="post" asp-action="ChangeStatus">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="status" class="form-select mb-2" asp-items="Html.GetEnumSelectList<TicketStatus>()"></select>
                        <button type="submit" class="btn btn-outline-primary w-100">Alterar status</button>
                    </form>

                    @if (User.IsInRole(RoleNames.Agent) && string.IsNullOrWhiteSpace(Model.AssignedTo))
                    {
                        <form method="post" asp-action="AssignToMe" class="mt-2">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-secondary w-100">Assumir chamado</button>
                        </form>
                    }
                </div>
            </div>
        }

        <div class="card surface-card">
            <div class="card-header">Histórico de status</div>
            <div class="card-body">
                @if (!Model.History.Any())
                {
                    <p class="text-muted">Sem histórico.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.History)
                        {
                            <li class="list-group-item px-0 timeline-item">
                                <div>
                                    <strong>@(item.FromStatus?.ToString() ?? "(inicial)")</strong>
                                    <span class="status-arrow">→</span>
                                    <strong>@item.ToStatus</strong>
                                </div>
                                <small class="comment-time">@item.ChangedBy · @item.ChangedAtUtc.ToLocalTime().ToString("g")</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
