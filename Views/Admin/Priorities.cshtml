@model Dictionary<gestao_chamados.Models.TicketPriority, TimeSpan>
@{
    ViewData["Title"] = "SLAs por prioridade";
}

<h2 class="page-title">SLAs por prioridade</h2>

<div class="card surface-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-modern mb-0">
                <thead>
                    <tr>
                        <th>Prioridade</th>
                        <th>Tempo máximo</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.OrderBy(x => x.Key))
                {
                    var slaPriCss = item.Key switch
                    {
                        gestao_chamados.Models.TicketPriority.Low => "low",
                        gestao_chamados.Models.TicketPriority.Medium => "medium",
                        gestao_chamados.Models.TicketPriority.High => "high",
                        gestao_chamados.Models.TicketPriority.Critical => "critical",
                        _ => "low"
                    };
                    var slaPriLabel = item.Key switch
                    {
                        gestao_chamados.Models.TicketPriority.Low => "Baixa",
                        gestao_chamados.Models.TicketPriority.Medium => "Média",
                        gestao_chamados.Models.TicketPriority.High => "Alta",
                        gestao_chamados.Models.TicketPriority.Critical => "Crítica",
                        _ => item.Key.ToString()
                    };
                    <tr>
                        <td><span class="badge-priority @slaPriCss">@slaPriLabel</span></td>
                        <td>@item.Value.TotalHours horas</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
