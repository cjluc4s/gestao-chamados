@model IEnumerable<gestao_chamados.Models.ApplicationUser>
@{
    ViewData["Title"] = "Usuários";
}

<h2 class="page-title">Usuários</h2>

<div class="card surface-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-modern mb-0">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Login</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.UserName</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
